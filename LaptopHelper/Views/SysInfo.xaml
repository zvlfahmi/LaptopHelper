<Page
    x:Class="LaptopHelper.Views.SysInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LaptopHelper.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
            <TextBlock Text="System Information" Style="{StaticResource TitleTextBlockStyle}"/>
            <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" VerticalAlignment="Center"/>
        </StackPanel>

        <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="True" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <ScrollViewer x:Name="ContentScrollViewer" Grid.Row="1" Visibility="Collapsed">
            <StackPanel Spacing="16" Margin="0,0,0,16" MaxWidth="800">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </StackPanel.Resources>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="20">
                        <TextBlock Text="Product Name" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Serial Number" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="SKU Number" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="System Board ID" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Memory Size" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Processor Type" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Processor Speed" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="UUID" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="UUID (Standard)" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Asset Tracking" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Ownership Tag" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="BIOS Version" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="20">
                        <TextBlock x:Name="TxtProductName" IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtSerialNumber" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtSkuNumber" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtBoardId" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtMemorySize" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtProcessorType" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtProcessorSpeed" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtUuid" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtUuidStandard" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtAssetTag" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtOwnershipTag" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="TxtBiosVersion" IsTextSelectionEnabled="True"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>